generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Location {
  id          Int          @id @default(autoincrement())
  name        String
  address     String?
  notes       String?
  parentId    Int?
  parent      Location?    @relation("LocationChildren", fields: [parentId], references: [id])
  children    Location[]   @relation("LocationChildren")
  createdAt   DateTime     @default(now())
  assets          Asset[]
  consumables     Consumable[]
  modelTemplates  ModelTemplate[]
}

model AssetPhoto {
  id        Int      @id @default(autoincrement())
  assetId   Int
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  path      String
  createdAt DateTime @default(now())
}

model Asset {
  id           Int           @id @default(autoincrement())
  name         String
  assetTag     String        @unique
  type         String        @default("")
  status       String        @default("available")
  locationId   Int?
  location     Location?     @relation(fields: [locationId], references: [id])
  assigneeId   Int?
  assignee     Person?       @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  serialNumber String?
  modelNumber  String?
  supplier     String?
  purchaseDate DateTime?
  value        Float?
  notes        String?
  createdAt    DateTime      @default(now())
  containerFor Kit[]         @relation("KitContainer")
  kitItems     KitItem[]
  allocations  Allocation[]  @relation("AllocationAssets")
  maintenance  Maintenance[]
  photos       AssetPhoto[]
  tags         AssetTag[]
}

model Tag {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  color     String     @default("#6366f1")
  createdAt DateTime   @default(now())
  assets    AssetTag[]
}

model AssetTag {
  assetId Int
  tagId   Int
  asset   Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([assetId, tagId])
}

model Person {
  id         Int      @id @default(autoincrement())
  name       String
  email      String?
  department String?
  createdAt  DateTime @default(now())
  assets     Asset[]
}

enum MaintenanceStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Maintenance {
  id                   Int               @id @default(autoincrement())
  assetId              Int
  asset                Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  title                String
  description          String?
  status               MaintenanceStatus @default(SCHEDULED)
  scheduledDate        DateTime?
  completedDate        DateTime?
  cost                 Float?
  repeatIntervalDays   Int?
  repeatEndDate        DateTime?
  parentId             Int?
  parent               Maintenance?      @relation("MaintenanceChain", fields: [parentId], references: [id], onDelete: SetNull)
  children             Maintenance[]     @relation("MaintenanceChain")
  createdAt            DateTime          @default(now())
}

model Allocation {
  id         Int                   @id @default(autoincrement())
  name       String
  startDate  DateTime
  endDate    DateTime?
  indefinite Boolean               @default(false)
  createdAt  DateTime              @default(now())
  assets     Asset[]               @relation("AllocationAssets")
  planItems  AllocationPlanItem[]
}

model AllocationPlanItem {
  id           Int        @id @default(autoincrement())
  allocationId Int
  allocation   Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  description  String
  modelNumber  String?
  quantity     Int        @default(1)
  notes        String?
  kitId        Int?
  kit          Kit?       @relation(fields: [kitId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
}

model Consumable {
  id           Int       @id @default(autoincrement())
  name         String
  quantity     Int       @default(0)
  reorderPoint Int       @default(5)
  unit         String    @default("each")
  modelNumber  String?
  notes        String?
  locationId   Int?
  location     Location? @relation(fields: [locationId], references: [id])
  createdAt    DateTime  @default(now())
}

model Status {
  id   Int    @id @default(autoincrement())
  name String @unique
}

enum Role {
  VIEW_ONLY
  ASSET_CONTROL
  MANAGEMENT
  ADMIN
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String?   @unique
  passwordHash String    @default("*")
  role         Role      @default(ADMIN)
  avatarPath   String?
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?
}

model OAuthProvider {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  label        String
  clientId     String
  clientSecret String
  enabled      Boolean  @default(true)
  defaultRole  Role     @default(VIEW_ONLY)
  // Custom OAuth2/OIDC endpoints (used when name is not google/apple)
  authUrl      String?
  tokenUrl     String?
  userinfoUrl  String?
  scope        String?
  // Apple-specific
  appleTeamId  String?
  appleKeyId   String?
  applePrivKey String?
  createdAt    DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

model ModelTemplate {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  type        String   @default("")
  modelNumber String?
  supplier    String?
  value       Float?
  locationId  Int?
  location    Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  notes       String?
  createdAt   DateTime @default(now())
}

model Kit {
  id          Int                  @id @default(autoincrement())
  name        String
  kitCode     String               @unique
  containerId Int?
  container   Asset?               @relation("KitContainer", fields: [containerId], references: [id], onDelete: SetNull)
  items       KitItem[]
  planItems   AllocationPlanItem[]
  createdAt   DateTime             @default(now())
}

model KitItem {
  kitId   Int
  assetId Int
  kit     Kit   @relation(fields: [kitId], references: [id], onDelete: Cascade)
  asset   Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@id([kitId, assetId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  userId     Int
  username   String
  action     String
  entity     String
  entityId   Int?
  entityName String?
  detail     String?
}
